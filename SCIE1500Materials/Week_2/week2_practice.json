  "questions": [
    {
      "id": "W2-Q1",
      "type": "multiple_choice",
      "topic": "Exponential equation solving",
      "exam_alignment": "Q8 style",
      "difficulty": "medium",
      "question": "A population grows according to $P(t) = 500e^{0.08t}$, where $t$ is in years. How many years will it take for the population to reach 2000?",
      "options": {
        "a": "12.5 years",
        "b": "17.3 years",
        "c": "25.0 years",
        "d": "8.7 years",
        "e": "None of the above"
      },
      "correct_answer": "b",
      "solution": {
        "steps": [
          "Set up equation: $500e^{0.08t} = 2000$",
          "Divide both sides by 500: $e^{0.08t} = 4$",
          "Take natural log: $0.08t = \\ln(4)$",
          "Solve: $t = \\ln(4)/0.08 = 1.386/0.08 = 17.33$ years"
        ],
        "final_answer": "17.3 years"
      },
      "key_concepts": [
        "Exponential equations",
        "Natural logarithm",
        "Solving for time"
      ]
    },
    {
      "id": "W2-Q2",
      "type": "multiple_choice",
      "topic": "Inverse functions",
      "exam_alignment": "Q20",
      "difficulty": "medium",
      "question": "What is the inverse of the function $f(x) = 3 + \\frac{1}{4}x$?",
      "options": {
        "a": "$f^{-1}(x) = -3 + 4x$",
        "b": "$f^{-1}(x) = -3 - \\frac{1}{4}x$",
        "c": "$f^{-1}(x) = \\frac{1}{4} - x$",
        "d": "$f^{-1}(x) = -12 + 4x$",
        "e": "None of the above"
      },
      "correct_answer": "d",
      "solution": {
        "steps": [
          "Start with $y = 3 + \\frac{1}{4}x$",
          "Swap $x$ and $y$: $x = 3 + \\frac{1}{4}y$",
          "Solve for $y$: $x - 3 = \\frac{1}{4}y$",
          "Multiply by 4: $y = 4(x - 3) = 4x - 12 = -12 + 4x$"
        ],
        "final_answer": "$f^{-1}(x) = -12 + 4x$"
      },
      "key_concepts": [
        "Inverse functions",
        "Swapping x and y",
        "Solving for y"
      ]
    },
    {
      "id": "W2-Q3",
      "type": "multiple_choice",
      "topic": "Function composition with exponentials",
      "exam_alignment": "Q23",
      "difficulty": "medium",
      "question": "If $f(x) = -e^{-2x+1}$ and $g(x) = -\\frac{1}{2}x^2$, what is $f \\circ g(x)$?",
      "options": {
        "a": "$(-e^{-2x+1})(-\\frac{1}{2})$",
        "b": "$-e^{x^2+1}$",
        "c": "$\\frac{1}{2}e^{4x^2-4x+1}$",
        "d": "$xe^{-2x+1}$",
        "e": "None of the above"
      },
      "correct_answer": "b",
      "solution": {
        "steps": [
          "$f \\circ g(x)$ means $f(g(x))$",
          "First compute $g(x) = -\\frac{1}{2}x^2$",
          "Now substitute into $f$: $f(g(x)) = -e^{-2(-\\frac{1}{2}x^2)+1}$",
          "Simplify exponent: $-2 \\times (-\\frac{1}{2}x^2) + 1 = x^2 + 1$",
          "Result: $f \\circ g(x) = -e^{x^2+1}$"
        ],
        "final_answer": "$-e^{x^2+1}$"
      },
      "key_concepts": [
        "Function composition",
        "Exponential functions",
        "Order of operations"
      ]
    },
    {
      "id": "W2-Q4",
      "type": "multiple_choice",
      "topic": "Logarithmic simplification",
      "exam_alignment": "Q23 style",
      "difficulty": "easy",
      "question": "Simplify: $\\ln(e^x) + \\ln(e^{3x})$",
      "options": {
        "a": "$\\ln(e^{4x})$",
        "b": "$3x^2$",
        "c": "$4x$",
        "d": "$e^{4x}$",
        "e": "None of the above"
      },
      "correct_answer": "c",
      "solution": {
        "steps": [
          "Use property $\\ln(e^a) = a$",
          "$\\ln(e^x) = x$",
          "$\\ln(e^{3x}) = 3x$",
          "Sum: $x + 3x = 4x$"
        ],
        "final_answer": "$4x$"
      },
      "key_concepts": [
        "Logarithm laws",
        "Inverse relationship of ln and exp"
      ]
    },
    {
      "id": "W2-Q5",
      "type": "multiple_choice",
      "topic": "Properties of probability functions",
      "exam_alignment": "Q27",
      "difficulty": "medium",
      "question": "Suppose the probability $p$ that a person contracts a disease is described as a function of risk $x$: $p = \\frac{1}{1+e^{-3x}}$. Which statement is NOT correct?",
      "options": {
        "a": "$p$ is $\\frac{1}{2}$ if $x = 0$",
        "b": "$p$ is below $\\frac{1}{2}$ if $x$ is negative",
        "c": "$p$ is an increasing function of $x$",
        "d": "$p$ approaches zero if $x$ goes towards $-\\infty$",
        "e": "None of the above (all statements are correct)"
      },
      "correct_answer": "e",
      "solution": {
        "steps": [
          "(a) When $x=0$: $p = \\frac{1}{1+e^0} = \\frac{1}{1+1} = \\frac{1}{2}$ ✓",
          "(b) When $x<0$: $e^{-3x} > 1$, so $1+e^{-3x} > 2$, so $p < \\frac{1}{2}$ ✓",
          "(c) As $x$ increases, $e^{-3x}$ decreases, so $p$ increases ✓",
          "(d) As $x \\to -\\infty$: $e^{-3x} \\to \\infty$, so $p \\to 0$ ✓",
          "All statements are correct"
        ],
        "final_answer": "None of the above (all are correct)"
      },
      "key_concepts": [
        "Logistic-type functions",
        "Exponential behaviour",
        "Function analysis"
      ]
    },
    {
      "id": "W2-Q6",
      "type": "multi_part",
      "topic": "Solving exponential equations",
      "exam_alignment": "Q8 preparation",
      "difficulty": "medium",
      "question": "Consider a population $P(t) = \\frac{K}{1+Ae^{-\\alpha t}}$ with $K=10000$, $A=99$, $\\alpha=0.1$.",
      "parts": [
        {
          "part": "a",
          "question": "What is the initial population $P(0)$?",
          "solution": {
            "steps": [
              "$P(0) = \\frac{10000}{1+99 \\times e^0} = \\frac{10000}{1+99} = \\frac{10000}{100} = 100$"
            ],
            "answer": "$P(0) = 100$"
          }
        },
        {
          "part": "b",
          "question": "What is the carrying capacity (maximum population)?",
          "solution": {
            "steps": [
              "As $t \\to \\infty$, $e^{-\\alpha t} \\to 0$",
              "So $P(\\infty) = \\frac{K}{1+0} = K = 10000$"
            ],
            "answer": "$K = 10{,}000$"
          }
        },
        {
          "part": "c",
          "question": "How long until the population reaches 5000 (50% of $K$)?",
          "solution": {
            "steps": [
              "Set $P(t) = 5000$: $\\frac{10000}{1+99e^{-0.1t}} = 5000$",
              "Simplify: $1+99e^{-0.1t} = 2$",
              "So: $99e^{-0.1t} = 1$",
              "Thus: $e^{-0.1t} = \\frac{1}{99}$",
              "Take $\\ln$: $-0.1t = \\ln(1/99) = -\\ln(99)$",
              "Solve: $t = \\frac{\\ln(99)}{0.1} = \\frac{4.595}{0.1} = 45.95$ time periods"
            ],
            "answer": "$t \\approx 46$ time periods"
          }
        }
      ],
      "key_concepts": [
        "Logistic function",
        "Initial conditions",
        "Carrying capacity",
        "Solving for time"
      ]
    },
    {
