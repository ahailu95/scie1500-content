    {
      "id": "W2-Q8",
      "type": "multi_part",
      "topic": "Geometric sequences",
      "exam_alignment": "Sequences foundation",
      "difficulty": "medium",
      "question": "A bacterial colony doubles every 3 hours. Initially there are 500 bacteria.",
      "parts": [
        {
          "part": "a",
          "question": "Write a formula for the population after n doubling periods.",
          "solution": {
            "steps": [
              "This is a geometric sequence with $a=500$ and $r=2$",
              "After $n$ periods: $P_n = 500 \\times 2^n$"
            ],
            "answer": "$P_n = 500 \\times 2^n$"
          }
        },
        {
          "part": "b",
          "question": "How many bacteria after 4 doubling periods (12 hours)?",
          "solution": {
            "steps": [
              "$P_4 = 500 \\times 2^4 = 500 \\times 16 = 8000$"
            ],
            "answer": "8,000 bacteria"
          }
        },
        {
          "part": "c",
          "question": "How many doubling periods until the population exceeds 1 million?",
          "solution": {
            "steps": [
              "Need: $500 \\times 2^n > 1{,}000{,}000$",
              "$2^n > 2000$",
              "$n \\times \\ln(2) > \\ln(2000)$",
              "$n > \\ln(2000)/\\ln(2) = 7.64/0.693 = 10.97$",
              "So $n = 11$ periods (33 hours)"
            ],
            "answer": "11 doubling periods"
          }
        },
        {
          "part": "d",
          "question": "Write this as a continuous exponential function $P(t)$ where $t$ is in hours.",
          "solution": {
            "steps": [
              "Doubling time $T = 3$ hours means $e^{kT} = 2$",
              "So $3k = \\ln(2)$, giving $k = \\ln(2)/3 \\approx 0.231$",
              "$P(t) = 500 \\times e^{0.231t}$"
            ],
            "answer": "$P(t) = 500e^{0.231t}$"
          }
        }
      ],
      "key_concepts": [
        "Geometric sequences",
        "Exponential growth",
        "Doubling time",
        "Discrete to continuous"
      ]
    },
    {
      "id": "W2-Q9",
      "type": "multiple_choice",
      "topic": "Domain identification",
      "exam_alignment": "Foundation skills",
      "difficulty": "medium",
      "question": "In which case is the Domain (D) for the function NOT identified correctly?",
      "options": {
        "a": "$y = -3 + 6x$, $D = \\{x : x \\in \\mathbb{R}\\}$",
        "b": "$y = \\frac{(2x-1)^{1/2}}{2} - 2$, $D = \\{x : x \\in \\mathbb{R}\\}$",
        "c": "$y = \\frac{2}{1-e^{-x}}$, $D = \\{x \\in \\mathbb{R} : x \\neq 0\\}$",
        "d": "$y = e^{-0.5x+2}$, $D = \\{x : x \\in \\mathbb{R}\\}$",
        "e": "None of the above"
      },
      "correct_answer": "b",
      "solution": {
        "steps": [
          "(a) Linear function: domain is all reals ✓",
          "(b) Square root requires $(2x-1) \\geq 0$, so $x \\geq 1/2$. Domain should be $\\{x : x \\geq 0.5\\}$ ✗",
          "(c) Need $1-e^{-x} \\neq 0$, which means $e^{-x} \\neq 1$, so $x \\neq 0$ ✓",
          "(d) Exponential is defined for all reals ✓",
          "Answer (b) has incorrect domain"
        ],
        "final_answer": "Option (b) is incorrect"
      },
      "key_concepts": [
        "Domain restrictions",
        "Square root functions",
        "Exponential domain"
      ]
    },
    {
      "id": "W2-Q10",
      "type": "multiple_choice",
      "topic": "Doubling time rule",
      "exam_alignment": "Population dynamics",
      "difficulty": "easy",
      "question": "A population grows at 2% per year. Using the '70 over r' rule, approximately how long will it take to double?",
      "options": {
        "a": "14 years",
        "b": "35 years",
        "c": "70 years",
        "d": "140 years",
