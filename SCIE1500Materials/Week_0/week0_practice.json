    {
      "id": "W0-Q1",
      "type": "multiple_choice",
      "difficulty": "easy",
      "topic": "Order of operations (BODMAS)",
      "question": "Evaluate: $3 + 2 \\times 4^2 - 10 \\div 2$",
      "options": {
        "a": "30",
        "b": "32",
        "c": "35",
        "d": "25",
        "e": "18"
      },
      "correct_answer": "a",
      "solution": {
        "steps": [
          "Apply BODMAS: Orders (exponents) first: $4^2 = 16$",
          "Expression becomes: $3 + 2 \\times 16 - 10 \\div 2$",
          "Multiplication and Division (left to right): $2 \\times 16 = 32$ and $10 \\div 2 = 5$",
          "Expression becomes: $3 + 32 - 5$",
          "Addition and Subtraction (left to right): $3 + 32 = 35$, then $35 - 5 = 30$"
        ],
        "final_answer": "30"
      },
      "hints": [
        "Remember BODMAS: Brackets, Orders (exponents), Division/Multiplication, Addition/Subtraction",
        "Calculate $4^2$ first",
        "Then do multiplication and division before addition and subtraction"
      ],
      "common_errors": [
        "Adding 3+2 first before multiplication",
        "Forgetting that exponents come before multiplication"
      ],
      "python_check": "print(3 + 2 * 4**2 - 10 / 2)  # Should output 30.0",
      "latex_display": true
    },
    {
      "id": "W0-Q2",
      "type": "multi_part",
      "difficulty": "medium",
      "topic": "Exponent rules",
      "question": "Simplify each expression using exponent rules.",
      "parts": [
        {
          "part": "a",
          "expression": "$\\frac{x^5 \\cdot x^3}{x^2}$",
          "answer": "$x^6$",
          "solution_steps": [
            "Numerator: $x^5 \\cdot x^3 = x^{5+3} = x^8$ (product rule)",
            "Then: $\\frac{x^8}{x^2} = x^{8-2} = x^6$ (quotient rule)"
          ]
        },
        {
          "part": "b",
          "expression": "$(2^3)^4$",
          "answer": "$2^{12} = 4096$",
          "solution_steps": [
            "Apply power rule: $(2^3)^4 = 2^{3 \\times 4} = 2^{12}$",
            "Calculate: $2^{12} = 4096$"
          ]
        },
        {
          "part": "c",
          "expression": "$8^{2/3}$",
          "answer": "$4$",
          "solution_steps": [
            "Rewrite: $8^{2/3} = (8^{1/3})^2$",
            "Calculate cube root: $8^{1/3} = \\sqrt[3]{8} = 2$",
            "Square it: $2^2 = 4$"
          ]
        },
        {
          "part": "d",
          "expression": "$5^{-2}$",
          "answer": "$\\frac{1}{25}$ or $0.04$",
          "solution_steps": [
            "Apply negative exponent rule: $5^{-2} = \\frac{1}{5^2}$",
            "Calculate: $\\frac{1}{25} = 0.04$"
          ]
        }
      ],
      "hints": [
        "Product rule: $a^m \\cdot a^n = a^{m+n}$",
        "Quotient rule: $a^m / a^n = a^{m-n}$",
        "Power rule: $(a^m)^n = a^{mn}$",
        "Fractional exponent: $a^{1/n} = \\sqrt[n]{a}$"
      ],
      "latex_display": true
    },
    {
      "id": "W0-Q3",
      "type": "multi_part",
      "difficulty": "medium",
      "topic": "Algebraic manipulation",
      "question": "Simplify or factor each expression.",
      "parts": [
        {
          "part": "a",
          "instruction": "Expand",
          "expression": "$(3x - 2)(x + 5)$",
          "answer": "$3x^2 + 13x - 10$",
          "solution_steps": [
            "Use FOIL or distribution:",
            "$3x \\cdot x = 3x^2$",
            "$3x \\cdot 5 = 15x$",
            "$-2 \\cdot x = -2x$",
            "$-2 \\cdot 5 = -10$",
            "Combine: $3x^2 + 15x - 2x - 10 = 3x^2 + 13x - 10$"
          ]
        },
        {
          "part": "b",
          "instruction": "Factor",
          "expression": "$x^2 - 16$",
          "answer": "$(x+4)(x-4)$",
          "solution_steps": [
            "Recognize as difference of squares: $a^2 - b^2 = (a+b)(a-b)$",
            "Here: $x^2 - 16 = x^2 - 4^2 = (x+4)(x-4)$"
          ]
        },
        {
          "part": "c",
          "instruction": "Simplify",
          "expression": "$\\frac{x^2 - 9}{x - 3}$",
          "answer": "$x + 3$ (for $x \\neq 3$)",
          "solution_steps": [
            "Factor numerator: $x^2 - 9 = (x+3)(x-3)$",
            "Simplify: $\\frac{(x+3)(x-3)}{x-3} = x+3$",
            "Note: undefined at $x = 3$"
          ]
        }
      ],
      "hints": [
        "For expansion, multiply each term in the first bracket by each term in the second",
        "Difference of squares: $a^2 - b^2 = (a+b)(a-b)$",
        "For rational expressions, factor first, then cancel common factors"
      ],
      "latex_display": true
    },
    {
      "id": "W0-Q4",
      "type": "multi_part",
      "difficulty": "medium",
      "topic": "Solving equations",
      "question": "Solve each equation for $x$.",
      "parts": [
        {
          "part": "a",
          "equation": "$5x - 7 = 3x + 9$",
          "answer": "$x = 8$",
          "solution_steps": [
            "Subtract $3x$ from both sides: $2x - 7 = 9$",
            "Add 7 to both sides: $2x = 16$",
            "Divide by 2: $x = 8$"
          ]
        },
        {
          "part": "b",
          "equation": "$x^2 - 7x + 12 = 0$",
          "answer": "$x = 3$ or $x = 4$",
          "solution_steps": [
            "Factor: Find two numbers that multiply to 12 and add to -7",
            "Those numbers are -3 and -4",
            "Factor: $(x-3)(x-4) = 0$",
            "Solutions: $x = 3$ or $x = 4$"
          ]
        },
        {
          "part": "c",
          "equation": "$2x^2 + 5x - 3 = 0$",
          "answer": "$x = \\frac{1}{2}$ or $x = -3$",
          "solution_steps": [
            "Use quadratic formula: $x = \\frac{-b \\pm \\sqrt{b^2-4ac}}{2a}$",
            "Here: $a=2$, $b=5$, $c=-3$",
            "Discriminant: $b^2 - 4ac = 25 + 24 = 49$",
            "$x = \\frac{-5 \\pm 7}{4}$",
            "$x = \\frac{-5+7}{4} = \\frac{2}{4} = \\frac{1}{2}$",
            "$x = \\frac{-5-7}{4} = \\frac{-12}{4} = -3$"
          ]
        }
      ],
      "hints": [
        "For linear equations, collect x terms on one side, constants on the other",
        "For quadratics, try factoring first; if that fails, use the quadratic formula",
        "Check your answers by substituting back into the original equation"
      ],
      "latex_display": true
    },
    {
      "id": "W0-Q5",
      "type": "multi_part",
      "difficulty": "medium",
      "topic": "Inequalities",
      "question": "Solve each inequality and express the answer in interval notation.",
      "parts": [
        {
          "part": "a",
          "inequality": "$3x + 5 > 14$",
          "answer": "$(3, \\infty)$",
          "solution_steps": [
            "Subtract 5: $3x > 9$",
            "Divide by 3: $x > 3$",
            "Interval notation: $(3, \\infty)$"
          ]
        },
        {
          "part": "b",
          "inequality": "$-4x + 2 \\leq 10$",
          "answer": "$[-2, \\infty)$",
          "solution_steps": [
            "Subtract 2: $-4x \\leq 8$",
            "Divide by -4 (REVERSE inequality): $x \\geq -2$",
            "Interval notation: $[-2, \\infty)$"
          ]
        },
        {
          "part": "c",
          "inequality": "$-1 < 2x + 3 \\leq 9$",
          "answer": "$(-2, 3]$",
          "solution_steps": [
            "Subtract 3 from all parts: $-4 < 2x \\leq 6$",
            "Divide by 2: $-2 < x \\leq 3$",
            "Interval notation: $(-2, 3]$"
          ]
        }
      ],
      "hints": [
        "Solve inequalities like equations, BUT flip the inequality when multiplying or dividing by a negative number",
        "Square bracket [ means included (≤ or ≥), round bracket ( means excluded (< or >)",
        "Infinity always uses round brackets"
      ],
      "common_errors": [
        "Forgetting to reverse the inequality when dividing by a negative",
        "Using square brackets with infinity"
      ],
      "latex_display": true
    },
