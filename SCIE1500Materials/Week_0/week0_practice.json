    {
      "id": "W0-Q7",
      "type": "multi_part",
      "difficulty": "medium",
      "topic": "Function notation",
      "context": "This is essential preparation for Week 1. Remember: $f(x)$ does NOT mean $f$ times $x$. It means 'the function $f$ evaluated at $x$'.",
      "question": "Given $f(x) = 3x^2 - 2x + 1$ and $g(x) = 5x - 4$, evaluate:",
      "parts": [
        {
          "part": "a",
          "expression": "$f(2)$",
          "answer": "$9$",
          "solution_steps": [
            "Substitute $x = 2$ into $f(x) = 3x^2 - 2x + 1$",
            "$f(2) = 3(2)^2 - 2(2) + 1$",
            "$f(2) = 3(4) - 4 + 1 = 12 - 4 + 1 = 9$"
          ]
        },
        {
          "part": "b",
          "expression": "$g(-1)$",
          "answer": "$-9$",
          "solution_steps": [
            "Substitute $x = -1$ into $g(x) = 5x - 4$",
            "$g(-1) = 5(-1) - 4 = -5 - 4 = -9$"
          ]
        },
        {
          "part": "c",
          "expression": "$f(0) + g(0)$",
          "answer": "$-3$",
          "solution_steps": [
            "$f(0) = 3(0)^2 - 2(0) + 1 = 1$",
            "$g(0) = 5(0) - 4 = -4$",
            "$f(0) + g(0) = 1 + (-4) = -3$"
          ]
        },
        {
          "part": "d",
          "expression": "$f(a)$ (leave in terms of $a$)",
          "answer": "$3a^2 - 2a + 1$",
          "solution_steps": [
            "Replace every $x$ with $a$",
            "$f(a) = 3a^2 - 2a + 1$"
          ]
        }
      ],
      "hints": [
        "To evaluate $f(2)$, replace every $x$ in the formula with $2$",
        "Be careful with negative numbers: $(-1)^2 = 1$, not $-1$",
        "Follow BODMAS when evaluating"
      ],
      "common_errors": [
        "Thinking $f(2) = f \\times 2$",
        "Sign errors when substituting negative values"
      ],
      "latex_display": true
    },
